#!/bin/bash

set -euo pipefail

app_name="pi"
package_name="@earendil-works/pi-coding-agent"
theme_name="karan-dark"

# Set PROFILE_DIR and APP_BIN if not already set
if [ -z "${PROFILE_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROFILE_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
else
    SCRIPT_DIR="${PROFILE_DIR}/bin/pi"
fi

if [ -z "${APP_BIN:-}" ]; then
    export APP_BIN="${PROFILE_DIR}/bin"
fi

. "${APP_BIN}/sh/shell_fns" --source-only
. "${APP_BIN}/sh/brew_helper.sh"

MACHINE="$(uname -s)"

check_node_version() {
    if command -v node >/dev/null 2>&1; then
        local node_version
        node_version=$(node --version | sed 's/v//' | cut -d. -f1)
        if [ "$node_version" -ge 18 ]; then
            return 0
        fi
    fi
    return 1
}

ensure_node() {
    if check_node_version; then
        return 0
    fi

    echo "Node.js 18+ is required. Installing/updating Node.js..."
    case "${MACHINE}" in
        Darwin)
            ensure_brew_in_path || {
                echo "ERROR: Homebrew not found. Please install Homebrew first."
                exit 1
            }
            if brew list node &>/dev/null; then
                echo "Upgrading Node.js..."
                brew upgrade node || brew install node
            else
                echo "Installing Node.js..."
                brew install node
            fi
            ;;
        Linux)
            if command -v apt-get >/dev/null 2>&1; then
                curl -fsSL https://deb.nodesource.com/setup_lts.x | sudo -E bash -
                sudo apt-get install -y nodejs
            elif command -v dnf >/dev/null 2>&1; then
                curl -fsSL https://rpm.nodesource.com/setup_lts.x | sudo bash -
                sudo dnf install -y nodejs
            elif command -v yum >/dev/null 2>&1; then
                curl -fsSL https://rpm.nodesource.com/setup_lts.x | sudo bash -
                sudo yum install -y nodejs
            else
                echo "ERROR: Could not install Node.js. Please install Node.js 18+ manually."
                exit 1
            fi
            ;;
        *)
            echo "Unsupported platform: ${MACHINE}"
            exit 1
            ;;
    esac
}

install_or_update_pi() {
    echo "Node.js version: $(node --version)"
    echo "npm version: $(npm --version)"

    if command -v pi >/dev/null 2>&1; then
        echo "pi already installed. Upgrading ${package_name}..."
    else
        echo "Installing pi..."
    fi

    npm install -g --ignore-scripts "${package_name}"
}

configure_theme() {
    local pi_agent_dir theme_dir settings_file theme_src theme_dst
    pi_agent_dir="${PI_AGENT_DIR:-${HOME}/.pi/agent}"
    theme_dir="${pi_agent_dir}/themes"
    settings_file="${pi_agent_dir}/settings.json"
    theme_src="${SCRIPT_DIR}/themes/${theme_name}.json"
    theme_dst="${theme_dir}/${theme_name}.json"

    if [ ! -f "$theme_src" ]; then
        echo "ERROR: missing pi theme source: ${theme_src}" >&2
        exit 1
    fi

    mkdir -p "$theme_dir"
    cp "$theme_src" "$theme_dst"

    SETTINGS_FILE="$settings_file" THEME_NAME="$theme_name" node <<'NODE'
const fs = require('fs');
const path = process.env.SETTINGS_FILE;
const theme = process.env.THEME_NAME;
let settings = {};
if (fs.existsSync(path)) {
  settings = JSON.parse(fs.readFileSync(path, 'utf8'));
}
settings.theme = theme;
fs.writeFileSync(path, JSON.stringify(settings, null, 2) + '\n');
NODE

    echo "Configured pi theme: ${theme_name}"
}

install_messages "start" "$app_name"
ensure_node

if ! command -v node >/dev/null 2>&1 || ! command -v npm >/dev/null 2>&1; then
    echo "ERROR: Node.js or npm not found after installation."
    exit 1
fi

install_or_update_pi
configure_theme

install_messages "end" "$app_name"

echo ""
echo "pi installed successfully!"
echo "Usage: pi --help"
echo "Theme: ${theme_name}"
echo ""
