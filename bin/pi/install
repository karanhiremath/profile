#!/bin/bash

set -euo pipefail

app_name="pi"
package_name="@earendil-works/pi-coding-agent"
theme_name="karan-dark"

# Set PROFILE_DIR and APP_BIN if not already set
if [ -z "${PROFILE_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROFILE_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
else
    SCRIPT_DIR="${PROFILE_DIR}/bin/pi"
fi

if [ -z "${APP_BIN:-}" ]; then
    export APP_BIN="${PROFILE_DIR}/bin"
fi

. "${APP_BIN}/sh/shell_fns" --source-only
. "${APP_BIN}/sh/brew_helper.sh"

MACHINE="$(uname -s)"

# node + pnpm are provided by mise (config/mise/config.toml). Guard on pnpm.
ensure_pnpm() {
    if command -v pnpm >/dev/null 2>&1 && command -v node >/dev/null 2>&1; then
        # pnpm requires its global bin dir on PATH before `pnpm add -g` will run.
        export PNPM_HOME="${PNPM_HOME:-${HOME}/.local/share/pnpm}"
        mkdir -p "${PNPM_HOME}/bin"
        case ":${PATH}:" in
            *":${PNPM_HOME}/bin:"*) ;;
            *) export PATH="${PNPM_HOME}/bin:${PATH}" ;;
        esac
        return 0
    fi
    echo "ERROR: node + pnpm are required and are provided by mise."
    echo "Run 'just mise' (or bin/mise/install), then re-run this installer."
    exit 1
}

install_or_update_pi() {
    echo "node version: $(node --version)"
    echo "pnpm version: $(pnpm --version)"

    if command -v pi >/dev/null 2>&1; then
        echo "pi already installed. Upgrading ${package_name}..."
    else
        echo "Installing pi..."
    fi

    pnpm add -g --ignore-scripts "${package_name}"
}

configure_pi_agent() {
    local pi_agent_dir theme_dir extensions_dir settings_file theme_src theme_dst agents_src settings_src extensions_src trust_file
    pi_agent_dir="${PI_AGENT_DIR:-${HOME}/.pi/agent}"
    theme_dir="${pi_agent_dir}/themes"
    extensions_dir="${pi_agent_dir}/extensions"
    settings_file="${pi_agent_dir}/settings.json"
    trust_file="${pi_agent_dir}/trust.json"
    theme_src="${SCRIPT_DIR}/themes/${theme_name}.json"
    theme_dst="${theme_dir}/${theme_name}.json"
    agents_src="${PROFILE_DIR}/config/pi/AGENTS.personal.md"
    settings_src="${PROFILE_DIR}/config/pi/settings.personal.json"
    extensions_src="${PROFILE_DIR}/config/pi/extensions"

    if [ ! -f "$theme_src" ]; then
        echo "ERROR: missing pi theme source: ${theme_src}" >&2
        exit 1
    fi
    if [ ! -f "$agents_src" ]; then
        echo "ERROR: missing pi personal AGENTS source: ${agents_src}" >&2
        exit 1
    fi
    if [ ! -f "$settings_src" ]; then
        echo "ERROR: missing pi personal settings source: ${settings_src}" >&2
        exit 1
    fi

    mkdir -p "$theme_dir" "$extensions_dir"
    cp "$theme_src" "$theme_dst"
    cp "$agents_src" "${pi_agent_dir}/AGENTS.md"
    cp "$settings_src" "$settings_file"
    if [ -d "$extensions_src" ] && compgen -G "${extensions_src}/*.ts" >/dev/null; then
        cp "${extensions_src}"/*.ts "$extensions_dir"/
    fi

    TRUST_FILE="$trust_file" HOME_DIR="$HOME" node <<'NODE'
const fs = require('fs');
const path = process.env.TRUST_FILE;
const home = process.env.HOME_DIR;
let trust = {};
if (fs.existsSync(path)) {
  try { trust = JSON.parse(fs.readFileSync(path, 'utf8')); } catch { trust = {}; }
}
for (const rel of ['src/profile', 'src/hermes', 'src/notes']) {
  trust[`${home}/${rel}`] = true;
}
fs.writeFileSync(path, JSON.stringify(trust, null, 2) + '\n');
NODE

    echo "Configured pi personal agent policy, trust, extensions, and theme: ${theme_name}"
}

install_messages "start" "$app_name"
ensure_pnpm

install_or_update_pi
configure_pi_agent

install_messages "end" "$app_name"

echo ""
echo "pi installed successfully!"
echo "Usage: pi --help"
echo "Theme: ${theme_name}"
echo ""
