#!/bin/bash

set -euo pipefail

shopt -s failglob

# Set PROFILE_DIR and APP_BIN if not already set
if [ -z "${PROFILE_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROFILE_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

if [ -z "${APP_BIN:-}" ]; then
    export APP_BIN="${PROFILE_DIR}/bin"
fi

. "${APP_BIN}/sh/shell_fns" --source-only
. "${APP_BIN}/sh/brew_helper.sh"

app_name="claude-code"

MACHINE="$(uname -s)"
ARCH="$(uname -m)"

# node + pnpm are provided by mise (config/mise/config.toml). Guard on pnpm.
ensure_pnpm() {
    if command -v pnpm >/dev/null 2>&1 && command -v node >/dev/null 2>&1; then
        # pnpm requires its global bin dir on PATH before `pnpm add -g` will run.
        export PNPM_HOME="${PNPM_HOME:-${HOME}/.local/share/pnpm}"
        mkdir -p "${PNPM_HOME}/bin"
        case ":${PATH}:" in
            *":${PNPM_HOME}/bin:"*) ;;
            *) export PATH="${PNPM_HOME}/bin:${PATH}" ;;
        esac
        return 0
    fi
    echo "ERROR: node + pnpm are required and are provided by mise."
    echo "Run 'just mise' (or bin/mise/install), then re-run this installer."
    exit 1
}

# Check if already installed
if command -v claude-code >/dev/null 2>&1; then
    echo "Claude Code already installed. Checking for updates..."
    ensure_pnpm
    echo "Upgrading Claude Code via pnpm..."
    pnpm add -g @anthropic-ai/claude-code
    exit 0
fi

install_messages "start" "$app_name"

ensure_pnpm

echo "node version: $(node --version)"
echo "pnpm version: $(pnpm --version)"

# Install Claude Code via pnpm (global)
echo "Installing Claude Code..."
case "${MACHINE}" in
    Darwin|Linux)
        pnpm add -g @anthropic-ai/claude-code
        ;;
    *)
        echo "Unsupported platform: ${MACHINE}"
        exit 1
        ;;
esac

install_messages "end" "$app_name"

echo ""
echo "Claude Code installed successfully!"
echo "Usage:"
echo "  claude-code --help           - Show help"
echo "  claude-code <prompt>         - Run Claude Code with a prompt"
echo ""
echo "Note: You'll need to set up your Anthropic API key."
echo "Visit: https://console.anthropic.com/ to get your API key"
echo ""
