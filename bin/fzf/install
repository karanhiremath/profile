#!/bin/bash

set -euo pipefail

shopt -s failglob

if [ -z "${PROFILE_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROFILE_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

if [ -z "${APP_BIN:-}" ]; then
    export APP_BIN="${PROFILE_DIR}/bin"
fi

. "${APP_BIN}/sh/shell_fns" --source-only
. "${APP_BIN}/sh/brew_helper.sh"

app_name="fzf"

usage() {
    cat <<'USAGE'
Usage: bin/fzf/install [--help]

Install fzf using the host package manager.
USAGE
}

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    usage
    exit 0
fi

MACHINE="$(uname -s)"

if command -v fzf >/dev/null 2>&1; then
    echo "fzf already installed: $(command -v fzf)"
    fzf --version 2>/dev/null || true
    exit 0
fi

install_messages "start" "$app_name"

case "${MACHINE}" in
    Darwin|Mac)
        echo "Installing fzf on Mac..."
        ensure_brew_in_path || {
            echo "ERROR: Homebrew not found. Please install Homebrew first."
            exit 1
        }
        brew install fzf
        ;;
    Linux)
        echo "Installing fzf on Linux..."
        if command -v apt-get >/dev/null 2>&1; then
            sudo apt-get update && sudo apt-get install -y fzf
        elif command -v dnf >/dev/null 2>&1; then
            sudo dnf install -y fzf
        elif command -v yum >/dev/null 2>&1; then
            sudo yum install -y fzf
        elif command -v pacman >/dev/null 2>&1; then
            sudo pacman -S --noconfirm fzf
        elif command -v apk >/dev/null 2>&1; then
            sudo apk add fzf
        elif command -v zypper >/dev/null 2>&1; then
            sudo zypper --non-interactive install fzf
        elif command -v nix >/dev/null 2>&1; then
            nix profile install nixpkgs#fzf
        else
            echo "No supported package manager found. Please install fzf manually from https://github.com/junegunn/fzf"
            exit 1
        fi
        ;;
    *)
        echo "Unsupported platform: ${MACHINE}"
        exit 1
        ;;
esac

if ! command -v fzf >/dev/null 2>&1; then
    echo "ERROR: fzf install completed but fzf is still not on PATH." >&2
    exit 1
fi

install_messages "end" "$app_name"
echo "fzf installed: $(command -v fzf)"
fzf --version 2>/dev/null || true
