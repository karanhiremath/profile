#!/usr/bin/env bash
# Launch the work Chief of Staff Hermes profile.
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

log() { printf 'cosw: %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

resolve_link() {
  local target="$1" dir next
  while [ -L "$target" ]; do
    dir="$(cd -P "$(dirname "$target")" && pwd)"
    next="$(readlink "$target")"
    case "$next" in /*) target="$next" ;; *) target="$dir/$next" ;; esac
  done
  printf '%s\n' "$target"
}

forced_host_tools() {
  local arg next
  while [ "$#" -gt 0 ]; do
    arg="$1"; shift
    case "$arg" in
      --host-tools) return 0 ;;
      --terminal-backend)
        next="${1:-}"
        [ "$next" = "local" ] && return 0
        [ "$#" -gt 0 ] && shift
        ;;
      --terminal-backend=local) return 0 ;;
      --) break ;;
    esac
  done
  [ "${HERMES_AGENT_TERMINAL_BACKEND:-}" = "local" ] || [ "${TERMINAL_ENV:-}" = "local" ]
}

strip_cosw_args() {
  COSW_ARGS=()
  local arg next
  while [ "$#" -gt 0 ]; do
    arg="$1"; shift
    case "$arg" in
      --refresh-gh-auth|--refresh-sandbox-auth)
        COSW_REFRESH_GH_AUTH_ONLY=1
        ;;
      --host-tools)
        export HERMES_AGENT_TERMINAL_BACKEND="${HERMES_AGENT_TERMINAL_BACKEND:-local}"
        export TERMINAL_ENV="${TERMINAL_ENV:-local}"
        ;;
      --terminal-backend)
        next="${1:-}"
        case "$next" in
          local|docker)
            export HERMES_AGENT_TERMINAL_BACKEND="$next"
            export TERMINAL_ENV="$next"
            [ "$#" -gt 0 ] && shift
            ;;
          *)
            COSW_ARGS+=("$arg")
            [ "$#" -gt 0 ] && { COSW_ARGS+=("$1"); shift; }
            ;;
        esac
        ;;
      --terminal-backend=local)
        export HERMES_AGENT_TERMINAL_BACKEND=local
        export TERMINAL_ENV=local
        ;;
      --terminal-backend=docker)
        export HERMES_AGENT_TERMINAL_BACKEND=docker
        export TERMINAL_ENV=docker
        ;;
      --)
        COSW_ARGS+=("--" "$@")
        break
        ;;
      *) COSW_ARGS+=("$arg") ;;
    esac
  done
}

json_array() {
  local out="[" sep="" item esc
  for item in "$@"; do
    esc="${item//\\/\\\\}"
    esc="${esc//\"/\\\"}"
    out+="$sep\"$esc\""
    sep=","
  done
  out+="]"
  printf '%s\n' "$out"
}

stage_gh_auth_for_sandbox() {
  local profile_home="$1" src="$HOME/.config/gh" dst tmp
  [ "${COSW_GH_AUTH:-1}" = "1" ] || return 0
  [ -f "$src/hosts.yml" ] || return 0
  dst="$profile_home/sandbox-auth/gh"
  tmp="$profile_home/sandbox-auth/gh.tmp.$$"
  mkdir -p "$tmp"
  [ ! -f "$src/config.yml" ] || cp "$src/config.yml" "$tmp/config.yml"
  cp "$src/hosts.yml" "$tmp/hosts.yml"
  # The container runs as uid 1000 and bind-mounted host files appear as root.
  # Keep the host parent private (profile_home is 0700) but make these staged
  # copies world-readable inside the read-only mount so gh can read them.
  chmod 0444 "$tmp"/*.yml
  chmod 0555 "$tmp"
  if [ -d "$dst" ] && [ ! -L "$dst" ]; then
    # Preserve the directory inode so already-running containers with this
    # directory bind-mounted read-only see refreshed files after host auth
    # rotation. Replacing the directory would leave those mounts pinned to the
    # old/deleted inode until the sandbox is restarted.
    chmod u+w "$dst" 2>/dev/null || true
    chmod u+w "$dst"/*.yml 2>/dev/null || true
    rm -f "$dst/hosts.yml" "$dst/config.yml"
    cp "$tmp"/*.yml "$dst/"
    chmod 0444 "$dst"/*.yml
    chmod 0555 "$dst"
    chmod -R u+w "$tmp" 2>/dev/null || true
    rm -rf "$tmp"
  else
    if [ -e "$dst" ]; then
      chmod -R u+w "$dst" 2>/dev/null || true
      rm -rf "$dst"
    fi
    mv "$tmp" "$dst"
  fi
  printf '%s\n' "$dst"
}

stage_gh_gitconfig_for_sandbox() {
  local profile_home="$1" dst git_name git_email
  [ "${COSW_GH_AUTH:-1}" = "1" ] || return 0
  dst="$profile_home/sandbox-auth/gitconfig"
  git_name="${COSW_GIT_USER_NAME:-$(git config --global user.name 2>/dev/null || true)}"
  git_email="${COSW_GIT_USER_EMAIL:-$(git config --global user.email 2>/dev/null || true)}"
  mkdir -p "$(dirname "$dst")"
  [ ! -e "$dst" ] || chmod u+w "$dst" 2>/dev/null || true
  : >"$dst"
  if [ -n "$git_name" ] || [ -n "$git_email" ]; then
    {
      printf '[user]\n'
      [ -z "$git_name" ] || printf '\tname = %s\n' "$git_name"
      [ -z "$git_email" ] || printf '\temail = %s\n' "$git_email"
    } >>"$dst"
  fi
  cat >>"$dst" <<'EOF'
[safe]
	directory = *
[url "https://github.com/"]
	insteadOf = git@github.com:
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
EOF
  chmod 0444 "$dst"
  printf '%s\n' "$dst"
}

stage_readable_skills_for_sandbox() {
  local profile_home="$1" src="$profile_home/skills" dst tmp
  [ -d "$src" ] || return 0
  dst="$profile_home/sandbox-readable/skills"
  tmp="$profile_home/sandbox-readable/skills.tmp.$$"
  mkdir -p "$tmp"
  cp -R "$src/." "$tmp/"
  chmod -R a+rX "$tmp" 2>/dev/null || true
  chmod 0555 "$tmp" 2>/dev/null || true
  if [ -e "$dst" ]; then
    chmod -R u+w "$dst" 2>/dev/null || true
    rm -rf "$dst"
  fi
  mv "$tmp" "$dst"
  printf '%s\n' "$dst"
}

copy_auth_tree_for_sandbox() {
  local src="$1" dst="$2" item rel parent
  [ -d "$src" ] || return 0
  mkdir -p "$dst"
  while IFS= read -r -d '' item; do
    rel="${item#$src/}"
    [ -n "$rel" ] && [ "$rel" != "$item" ] || continue
    parent="$dst/$(dirname "$rel")"
    mkdir -p "$parent"
    if [ -d "$item" ] && [ ! -L "$item" ]; then
      mkdir -p "$dst/$rel"
    elif [ -f "$item" ]; then
      cp -p "$item" "$dst/$rel"
    elif [ -L "$item" ]; then
      cp -P "$item" "$dst/$rel"
    fi
  done < <(find "$src" -mindepth 1 \( -type d -o -type f -o -type l \) -print0 2>/dev/null)
}

stage_auth_dir_for_sandbox() {
  local profile_home="$1" name="$2" src="$3" dst tmp
  [ -d "$src" ] || return 0
  dst="$profile_home/sandbox-auth/$name"
  tmp="$profile_home/sandbox-auth/$name.tmp.$$"
  mkdir -p "$tmp"
  copy_auth_tree_for_sandbox "$src" "$tmp"
  find "$tmp" -type d -exec chmod 0555 {} + 2>/dev/null || true
  find "$tmp" -type f -exec chmod 0444 {} + 2>/dev/null || true
  if [ -d "$dst" ] && [ ! -L "$dst" ]; then
    # Preserve the directory inode so existing read-only bind mounts keep seeing
    # refreshed auth. Copy over current files without an empty-window delete;
    # stale cache files are safer than transiently missing auth during a plan.
    chmod -R u+w "$dst" 2>/dev/null || true
    cp -R "$tmp/." "$dst/"
    find "$dst" -type d -exec chmod 0555 {} + 2>/dev/null || true
    find "$dst" -type f -exec chmod 0444 {} + 2>/dev/null || true
    chmod -R u+w "$tmp" 2>/dev/null || true
    rm -rf "$tmp"
  else
    if [ -e "$dst" ]; then
      chmod -R u+w "$dst" 2>/dev/null || true
      rm -rf "$dst"
    fi
    mv "$tmp" "$dst"
  fi
  printf '%s\n' "$dst"
}

stage_aws_auth_for_sandbox() {
  local profile_home="$1" src="$HOME/.aws"
  [ "${COSW_AWS_AUTH:-1}" = "1" ] || return 0
  [ -d "$src" ] || return 0
  # Stage readable copies under the private profile home instead of mounting the
  # host ~/.aws directly: bind-mounted 0600 files are unreadable to the sandbox
  # uid. Never print these files; they may contain SSO/session auth material.
  stage_auth_dir_for_sandbox "$profile_home" aws "$src"
}

stage_op_auth_for_sandbox() {
  local profile_home="$1" src="$HOME/.config/op"
  [ "${COSW_OP_AUTH:-1}" = "1" ] || return 0
  [ -d "$src" ] || return 0
  # 1Password CLI account metadata/session state; never print contents.
  stage_auth_dir_for_sandbox "$profile_home" op "$src"
}

refresh_running_gh_auth() {
  local podman="$1" gh_auth_dir="$2" gh_gitconfig="${3:-}" skills_ro_dir="${4:-}" aws_auth_dir="${5:-}" op_auth_dir="${6:-}" cid name ok=0 failed=0
  [ -n "$gh_auth_dir" ] || return 0
  [ -f "$gh_auth_dir/hosts.yml" ] || return 0
  while read -r cid; do
    [ -n "$cid" ] || continue
    name="$($podman inspect "$cid" --format '{{.Name}}' 2>/dev/null || printf '%s' "$cid")"
    [ "${COSW_AUTH_SYNC_QUIET:-0}" = "1" ] || log "refreshing sandbox auth in running sandbox $name"
    "$podman" exec -u 0 "$cid" sh -lc 'mkdir -p /home/hermes/.config/gh /root/.config/gh; chmod 0755 /home/hermes/.config /root/.config 2>/dev/null || true; chmod u+w /home/hermes/.config/gh /root/.config/gh 2>/dev/null || true' >/dev/null 2>&1 || true
    if "$podman" cp "$gh_auth_dir/." "$cid:/home/hermes/.config/gh/" >/dev/null 2>&1; then
      "$podman" exec -u 0 "$cid" sh -lc 'cp -f /home/hermes/.config/gh/*.yml /root/.config/gh/ 2>/dev/null || true; chmod 0555 /home/hermes/.config/gh /root/.config/gh 2>/dev/null || true; chmod 0444 /home/hermes/.config/gh/*.yml /root/.config/gh/*.yml 2>/dev/null || true' >/dev/null 2>&1 || true
    fi
    if [ -n "$gh_gitconfig" ] && [ -f "$gh_gitconfig" ]; then
      "$podman" cp "$gh_gitconfig" "$cid:/home/hermes/.gitconfig" >/dev/null 2>&1 || true
      "$podman" cp "$gh_gitconfig" "$cid:/root/.gitconfig" >/dev/null 2>&1 || true
      "$podman" exec -u 0 "$cid" sh -lc 'chmod 0444 /home/hermes/.gitconfig /root/.gitconfig 2>/dev/null || true' >/dev/null 2>&1 || true
    fi
    if [ -n "$skills_ro_dir" ] && [ -d "$skills_ro_dir" ]; then
      if ! "$podman" exec "$cid" test -f /home/hermes/.hermes/skills/workflows/handoff-bootstrap/SKILL.md 2>/dev/null; then
        "$podman" exec -u 0 "$cid" sh -lc 'mkdir -p /home/hermes/.hermes/skills; chmod -R u+w /home/hermes/.hermes/skills 2>/dev/null || true' >/dev/null 2>&1 || true
        "$podman" cp "$skills_ro_dir/." "$cid:/home/hermes/.hermes/skills/" >/dev/null 2>&1 || true
        "$podman" exec -u 0 "$cid" sh -lc 'chmod -R a+rX /home/hermes/.hermes 2>/dev/null || true' >/dev/null 2>&1 || true
      fi
    fi
    if [ -n "$aws_auth_dir" ] && [ -d "$aws_auth_dir" ]; then
      "$podman" exec -u 0 "$cid" sh -lc 'mkdir -p /home/hermes/.aws /root/.aws; chmod -R u+w /home/hermes/.aws /root/.aws 2>/dev/null || true' >/dev/null 2>&1 || true
      "$podman" cp "$aws_auth_dir/." "$cid:/home/hermes/.aws/" >/dev/null 2>&1 || true
      "$podman" cp "$aws_auth_dir/." "$cid:/root/.aws/" >/dev/null 2>&1 || true
      "$podman" exec -u 0 "$cid" sh -lc 'chmod -R a+rX /home/hermes/.aws /root/.aws 2>/dev/null || true' >/dev/null 2>&1 || true
    fi
    if [ -n "$op_auth_dir" ] && [ -d "$op_auth_dir" ]; then
      "$podman" exec -u 0 "$cid" sh -lc 'mkdir -p /home/hermes/.config/op /root/.config/op; chmod -R u+w /home/hermes/.config/op /root/.config/op 2>/dev/null || true' >/dev/null 2>&1 || true
      "$podman" cp "$op_auth_dir/." "$cid:/home/hermes/.config/op/" >/dev/null 2>&1 || true
      "$podman" cp "$op_auth_dir/." "$cid:/root/.config/op/" >/dev/null 2>&1 || true
      "$podman" exec -u 0 "$cid" sh -lc 'chmod -R a+rX /home/hermes/.config/op /root/.config/op 2>/dev/null || true' >/dev/null 2>&1 || true
    fi
    if "$podman" exec "$cid" sh -lc 'HOME=/home/hermes gh auth status -h github.com >/dev/null 2>&1 && HOME=/home/hermes git config --global credential.https://github.com.helper >/dev/null 2>&1' >/dev/null 2>&1; then
      ok=$((ok + 1))
    else
      [ "${COSW_AUTH_SYNC_QUIET:-0}" = "1" ] || log "sandbox auth refresh did not validate in running sandbox $name"
      failed=$((failed + 1))
    fi
  done < <("$podman" ps --filter label=hermes-profile=chief-of-staff-work --format '{{.ID}}' 2>/dev/null || true)
  [ "$ok$failed" = "00" ] || [ "${COSW_AUTH_SYNC_QUIET:-0}" = "1" ] || log "running sandbox auth refresh: ok=$ok failed=$failed"
  [ "$failed" -eq 0 ]
}

sync_sandbox_auth_once() {
  local profile_home="$1" podman="${2:-}" gh_auth_dir gh_gitconfig skills_ro_dir aws_auth_dir op_auth_dir
  mkdir -p "$profile_home"
  gh_auth_dir="$(stage_gh_auth_for_sandbox "$profile_home" || true)"
  gh_gitconfig="$(stage_gh_gitconfig_for_sandbox "$profile_home" || true)"
  skills_ro_dir="$(stage_readable_skills_for_sandbox "$profile_home" || true)"
  aws_auth_dir="$(stage_aws_auth_for_sandbox "$profile_home" || true)"
  op_auth_dir="$(stage_op_auth_for_sandbox "$profile_home" || true)"
  if [ -n "$podman" ] && [ -x "$podman" ] && [ -n "$gh_auth_dir" ]; then
    refresh_running_gh_auth "$podman" "$gh_auth_dir" "$gh_gitconfig" "$skills_ro_dir" "$aws_auth_dir" "$op_auth_dir" || true
  fi
}

start_sandbox_auth_sync() {
  local profile_home="$1" podman="$2" pidfile logdir logfile pid script
  [ "${COSW_AUTH_SYNC:-1}" = "1" ] || return 0
  logdir="$profile_home/logs"
  mkdir -p "$profile_home/sandbox-auth" "$logdir"
  pidfile="$profile_home/sandbox-auth/auth-sync.pid"
  logfile="$logdir/sandbox-auth-sync.log"
  if [ -f "$pidfile" ]; then
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      return 0
    fi
  fi
  script="$SCRIPT_DIR/$(basename "$SOURCE")"
  nohup env COSW_AUTH_SYNC_QUIET=1 COSW_SKIP_PREFLIGHT=1 "$script" --sandbox-auth-sync-daemon "$profile_home" "$podman" >>"$logfile" 2>&1 &
  printf '%s\n' "$!" >"$pidfile"
}

run_sandbox_auth_sync_daemon() {
  local profile_home="$1" podman="$2" interval
  interval="${COSW_AUTH_SYNC_INTERVAL:-30}"
  while :; do
    sync_sandbox_auth_once "$profile_home" "$podman" || true
    sleep "$interval"
  done
}

wait_for_podman_info() {
  local podman="$1" tries="${2:-30}" delay="${3:-1}" i=0
  while [ "$i" -lt "$tries" ]; do
    "$podman" info >/dev/null 2>&1 && return 0
    i=$((i + 1))
    sleep "$delay"
  done
  return 1
}

ensure_podman_machine_ready() {
  local podman="$1"
  wait_for_podman_info "$podman" 2 1 && return 0
  log "Podman machine unavailable; starting default machine"
  if ! "$podman" machine start >/dev/null 2>&1; then
    "$podman" machine list >&2 || true
    die "podman machine start failed"
  fi
  if ! wait_for_podman_info "$podman" "${COSW_PODMAN_READY_TRIES:-45}" 1; then
    "$podman" machine list >&2 || true
    die "podman machine started but podman is not reachable"
  fi
}

sandbox_variant() {
  printf '%s\n' "${COSW_SANDBOX_VARIANT:-${HERMES_SANDBOX_VARIANT:-python-node-fedora}}"
}

sandbox_builder() {
  printf '%s\n' "${HERMES_PRIVATE_DIR:-$HOME/src/hermes}/scripts/build-sandbox-image.sh"
}

build_sandbox_image() {
  local podman="$1" image="$2" variant builder
  variant="$(sandbox_variant)"
  builder="$(sandbox_builder)"
  [ "${COSW_AUTO_BUILD_IMAGE:-1}" = "1" ] || return 1
  [ -x "$builder" ] || return 1
  log "building sandbox image $image via $variant"
  PODMAN_BINARY="$podman" IMAGE_TAG="$image" "$builder" "$variant"
}

ensure_toolchain() {
  local toolchain bun herm py target shim_dir
  toolchain="${HERMES_TOOLCHAIN_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/hermes-toolchain}"
  shim_dir="${HERMES_SHIM_DIR:-$HOME/.local/bin}"
  bun="$toolchain/bun/bin/bun"
  herm="$shim_dir/herm"
  py="$toolchain/venv/bin/python"

  if [ ! -x "$py" ] || [ ! -e "$herm" ]; then
    log "Hermes toolchain incomplete; running install --skip-private-sync"
    "$SCRIPT_DIR/install" --skip-private-sync
  fi
  if [ ! -x "$bun" ]; then
    log "Herm TUI Bun runtime missing; running install-tui"
    "$SCRIPT_DIR/install-tui"
  fi
  [ -e "$herm" ] || die "herm binary missing after install: $herm"
  target="$(resolve_link "$herm")"
  if [ -f "$target" ] && [ ! -x "$target" ]; then
    log "fixing non-executable herm entrypoint: $target"
    chmod 0755 "$target"
  fi
}

ensure_podman() {
  local podman socket image builder
  podman="${HERMES_DOCKER_BINARY:-$(command -v podman 2>/dev/null || true)}"
  [ -n "$podman" ] || die "podman not found; install podman or launch with --host-tools"
  [ -x "$podman" ] || podman="$(command -v "$podman" 2>/dev/null || true)"
  [ -n "$podman" ] || die "podman not executable: ${HERMES_DOCKER_BINARY:-podman}"

  export HERMES_DOCKER_BINARY="$podman"
  export HERMES_AGENT_TERMINAL_BACKEND="${HERMES_AGENT_TERMINAL_BACKEND:-docker}"
  export TERMINAL_ENV="${TERMINAL_ENV:-docker}"
  # Keep the agent context cwd host-readable.  The Docker sandbox has /workspace
  # mounted separately; using /root here makes the host-side prompt builder stat
  # /root/.git and crash with EACCES before the container turn can start.
  export TERMINAL_CWD="${COSW_TERMINAL_CWD:-/workspace}"

  ensure_podman_machine_ready "$podman"

  socket="$("$podman" machine inspect --format '{{.ConnectionInfo.PodmanSocket.Path}}' 2>/dev/null | head -n 1 || true)"
  if [ -n "$socket" ] && [ -S "$socket" ]; then
    export DOCKER_HOST="${DOCKER_HOST:-unix://$socket}"
  fi

  image="${HERMES_SANDBOX_IMAGE:-localhost/hermes-agent/python-node:dev}"
  export TERMINAL_DOCKER_IMAGE="${TERMINAL_DOCKER_IMAGE:-$image}"

  local observer_dir profile_home gh_auth_dir gh_gitconfig skills_ro_dir aws_auth_dir op_auth_dir volumes
  observer_dir="${COSW_HOST_OBSERVER_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/hermes-agents/chief-of-staff-work/host-observer}"
  profile_home="${XDG_DATA_HOME:-$HOME/.local/share}/hermes-agents/chief-of-staff-work/profiles/chief-of-staff-work"
  mkdir -p "$observer_dir" "$profile_home"
  chmod 0700 "$profile_home" 2>/dev/null || true
  gh_auth_dir="$(stage_gh_auth_for_sandbox "$profile_home" || true)"
  gh_gitconfig="$(stage_gh_gitconfig_for_sandbox "$profile_home" || true)"
  skills_ro_dir="$(stage_readable_skills_for_sandbox "$profile_home" || true)"
  aws_auth_dir="$(stage_aws_auth_for_sandbox "$profile_home" || true)"
  op_auth_dir="$(stage_op_auth_for_sandbox "$profile_home" || true)"
  if [ "${COSW_HOST_OBSERVER:-1}" = "1" ] && [ -x "$SCRIPT_DIR/cosw-host-observer" ]; then
    "$SCRIPT_DIR/cosw-host-observer" start --state-dir "$observer_dir" >/dev/null || \
      log "host observer failed to start; continuing without live host snapshot"
  fi

  volumes=(
    "$HOME/src:/root/src"
    "$HOME/src:/home/hermes/src"
    "$observer_dir:/home/hermes/.cosw-host:ro"
    "$observer_dir:/root/.cosw-host:ro"
  )
  if [ -n "$gh_auth_dir" ]; then
    volumes+=("$gh_auth_dir:/home/hermes/.config/gh:ro" "$gh_auth_dir:/root/.config/gh:ro")
    refresh_running_gh_auth "$podman" "$gh_auth_dir" "$gh_gitconfig" "$skills_ro_dir" "$aws_auth_dir" "$op_auth_dir" || true
  fi
  [ -z "$gh_gitconfig" ] || volumes+=("$gh_gitconfig:/home/hermes/.gitconfig:ro" "$gh_gitconfig:/root/.gitconfig:ro")
  [ -z "$skills_ro_dir" ] || volumes+=("$skills_ro_dir:/home/hermes/.hermes/skills:ro")
  [ -z "$aws_auth_dir" ] || volumes+=("$aws_auth_dir:/home/hermes/.aws:ro" "$aws_auth_dir:/root/.aws:ro")
  [ -z "$op_auth_dir" ] || volumes+=("$op_auth_dir:/home/hermes/.config/op:ro" "$op_auth_dir:/root/.config/op:ro")
  [ ! -d "$HOME/.pi/agent/sessions" ] || volumes+=("$HOME/.pi/agent/sessions:/mnt/host-pi-agent-sessions:ro")
  [ ! -d "$HOME/.pi/sessions" ] || volumes+=("$HOME/.pi/sessions:/mnt/host-pi-sessions:ro")
  [ ! -d "$HOME/.claude/projects" ] || volumes+=("$HOME/.claude/projects:/mnt/host-claude-projects:ro")
  [ ! -d "$HOME/.claude/session-env" ] || volumes+=("$HOME/.claude/session-env:/mnt/host-claude-session-env:ro")
  [ ! -d "$HOME/.codex/sessions" ] || volumes+=("$HOME/.codex/sessions:/mnt/host-codex-sessions:ro")
  [ ! -d "$HOME/.codex/process_manager" ] || volumes+=("$HOME/.codex/process_manager:/mnt/host-codex-process-manager:ro")
  export TERMINAL_DOCKER_VOLUMES="${TERMINAL_DOCKER_VOLUMES:-$(json_array "${volumes[@]}")}"
  export TERMINAL_DOCKER_PERSIST_ACROSS_PROCESSES="${TERMINAL_DOCKER_PERSIST_ACROSS_PROCESSES:-false}"
  if ! "$podman" image inspect "$image" >/dev/null 2>&1; then
    build_sandbox_image "$podman" "$image" || true
  fi
  "$podman" image inspect "$image" >/dev/null 2>&1 || \
    die "sandbox image missing: $image (run: PODMAN_BINARY=$podman IMAGE_TAG=$image $(sandbox_builder) $(sandbox_variant))"

  local home name smoke volume_args=() vol
  home="$profile_home"
  mkdir -p "$home/sandboxes/docker/default/home" "$home/sandboxes/docker/default/workspace" \
    "$home/skills" "$home/image_cache" "$home/audio_cache"
  # Hermes mounts profile skills read-only into Docker sandboxes at
  # /root/.hermes/skills. The sandbox process runs as uid 1000; if the host
  # skill tree is 0700/0600, skill references are mounted but unreadable.
  # Keep the profile home private, but make the intentionally mounted skill
  # tree world-readable/executable inside the read-only sandbox mount.
  chmod 0755 "$home/skills" 2>/dev/null || true
  chmod -R a+rX "$home/skills" 2>/dev/null || true
  for vol in "${volumes[@]}"; do
    volume_args+=("-v" "$vol")
  done
  name="cosw-smoke-$$"
  smoke="${TMPDIR:-/tmp}/cosw-podman-smoke-$$.log"
  run_smoke() {
    "$podman" run --rm --init --name "$name" \
      -w "$TERMINAL_CWD" \
      --cap-drop ALL --cap-add DAC_OVERRIDE --cap-add CHOWN --cap-add FOWNER \
      --security-opt no-new-privileges --pids-limit 256 \
      --tmpfs /tmp:rw,nosuid,size=512m --tmpfs /var/tmp:rw,noexec,nosuid,size=256m --tmpfs /run:rw,noexec,nosuid,size=64m \
      -v "$home/sandboxes/docker/default/home:/root" \
      -v "$home/sandboxes/docker/default/workspace:/workspace" \
      "${volume_args[@]}" \
      --cpus 1.0 --memory 5120m \
      -v "$home/skills:/root/.hermes/skills:ro" \
      -v "$home/image_cache:/root/.hermes/cache/images:ro" \
      -v "$home/audio_cache:/root/.hermes/cache/audio:ro" \
      "$image" sh -lc 'set -e; test -d /root/src; test -f /root/.cosw-host/current/SUMMARY.md; (python --version >/dev/null 2>&1 || python3 --version >/dev/null); gh --version >/dev/null; terraform version >/dev/null; aws --version >/dev/null; op --version >/dev/null; test ! -f /home/hermes/.config/gh/hosts.yml || test -s /home/hermes/.config/gh/hosts.yml; HOME=/home/hermes git config --global credential.https://github.com.helper >/dev/null; test ! -d /home/hermes/.hermes/skills/workflows/handoff-bootstrap || test -f /home/hermes/.hermes/skills/workflows/handoff-bootstrap/SKILL.md' >"$smoke" 2>&1
  }
  if ! run_smoke; then
    cat "$smoke" >&2 || true
    "$podman" rm -f "$name" >/dev/null 2>&1 || true
    if [ "${COSW_REBUILD_ON_SMOKE_FAIL:-1}" = "1" ] && build_sandbox_image "$podman" "$image"; then
      if ! run_smoke; then
        cat "$smoke" >&2 || true
        "$podman" rm -f "$name" >/dev/null 2>&1 || true
        die "podman sandbox smoke test failed after rebuild"
      fi
    else
      die "podman sandbox smoke test failed"
    fi
  fi
  rm -f "$smoke"
  start_sandbox_auth_sync "$profile_home" "$podman"

  local cid details running
  while read -r cid; do
    [ -n "$cid" ] || continue
    details="$("$podman" inspect "$cid" --format '{{.ImageName}} {{json .Mounts}}' 2>/dev/null || true)"
    case "$details" in
      *"$image"*"/root/src"*"/home/hermes/src"*"/root/.cosw-host"*) ;;
      *)
        running="$("$podman" inspect "$cid" --format '{{.State.Running}}' 2>/dev/null || true)"
        if [ "$running" = "true" ]; then
          log "running stale CoS-W sandbox container remains active: $cid (close cosw before removing)"
        else
          log "removing stopped stale CoS-W sandbox container: $cid"
          "$podman" rm -f "$cid" >/dev/null 2>&1 || true
        fi
        ;;
    esac
  done < <("$podman" ps -a --filter label=hermes-profile=chief-of-staff-work --format '{{.ID}}' 2>/dev/null || true)
}

if [ "${1:-}" = "--sandbox-auth-sync-daemon" ]; then
  shift
  run_sandbox_auth_sync_daemon "${1:?profile_home required}" "${2:-}"
fi

COSW_REFRESH_GH_AUTH_ONLY=0
for arg in "$@"; do
  { [ "$arg" = "--refresh-gh-auth" ] || [ "$arg" = "--refresh-sandbox-auth" ]; } && COSW_REFRESH_GH_AUTH_ONLY=1
done

if [ "$COSW_REFRESH_GH_AUTH_ONLY" = "1" ] || [ "${COSW_SKIP_PREFLIGHT:-0}" != "1" ]; then
  ensure_toolchain
  if [ "$COSW_REFRESH_GH_AUTH_ONLY" = "1" ] || ! forced_host_tools "$@"; then
    ensure_podman
  fi
fi

if [ "$COSW_REFRESH_GH_AUTH_ONLY" = "1" ]; then
  log "sandbox auth staged and refreshed for running CoS-W sandboxes"
  exit 0
fi

strip_cosw_args "$@"
exec "$SCRIPT_DIR/agents" up chief-of-staff-work "${COSW_ARGS[@]}"
