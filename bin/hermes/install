#!/usr/bin/env bash
# Install Hermes CLI tooling into an isolated user-local toolchain.
# Usage: install [--skip-private-sync]
set -euo pipefail

usage() { sed -n '2,3p' "$0" | sed 's/^# //'; }

SKIP_PRIVATE_SYNC=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    --skip-private-sync) SKIP_PRIVATE_SYNC=1; shift ;;
    -h|--help|help) usage; exit 0 ;;
    *) echo "ERROR: unknown arg: $1" >&2; usage >&2; exit 2 ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HERMES_TOOLCHAIN_HOME="${HERMES_TOOLCHAIN_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/hermes-toolchain}"
# Isolated, toolchain-local pnpm home. pnpm derives its global bin dir, global
# node_modules (global-dir), and content-addressable store from PNPM_HOME, so
# setting this scopes the entire pnpm global install into the toolchain.
PNPM_HOME="${HERMES_PNPM_HOME:-$HERMES_TOOLCHAIN_HOME/pnpm}"
export PNPM_HOME
VENV="${HERMES_PYTHON_VENV:-$HERMES_TOOLCHAIN_HOME/venv}"
BUN_HOME="${HERMES_BUN_HOME:-$HERMES_TOOLCHAIN_HOME/bun}"
SHIM_DIR="${HERMES_SHIM_DIR:-$HOME/.local/bin}"

for bin in node pnpm uv git; do
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "ERROR: required binary not found: $bin" >&2
    exit 127
  fi
done

mkdir -p "$HERMES_TOOLCHAIN_HOME" "$PNPM_HOME/bin" "$SHIM_DIR"

# Pin the toolchain venv to Python 3.13. hermes-agent's npm postinstall
# pip-installs hermes-agent==0.18.2, whose Requires-Python is >=3.11,<3.14, so
# the venv MUST be <3.14 — mise's default Python (e.g. 3.14) breaks the install.
# uv fetches CPython 3.13 on demand; no mise change needed. Do NOT bump this back
# to the default without confirming hermes-agent supports the newer Python.
HERMES_VENV_PYTHON="3.13"
if [ -x "$VENV/bin/python" ]; then
  _venv_ver="$("$VENV/bin/python" -c 'import sys; print("%d.%d" % sys.version_info[:2])' 2>/dev/null || true)"
  if [ "$_venv_ver" != "$HERMES_VENV_PYTHON" ]; then
    # --allow-existing will not downgrade an existing (e.g. 3.14) venv, so a
    # version mismatch must be recreated from scratch.
    echo "Recreating hermes venv: found Python ${_venv_ver:-unknown}, need ${HERMES_VENV_PYTHON}"
    rm -rf "$VENV"
  fi
fi
uv venv --python "$HERMES_VENV_PYTHON" --allow-existing --seed "$VENV"
uv pip install --python "$VENV/bin/python" pip setuptools wheel PyYAML

# pnpm's global bin dir is $PNPM_HOME/bin and MUST be on PATH before `pnpm add -g`
# (otherwise pnpm refuses to install and `pnpm bin -g`/`pnpm root -g` return an
# error string instead of a path).
export PATH="$VENV/bin:$PNPM_HOME/bin:$PATH"

pnpm add -g --allow-build=hermes-agent --allow-build=herm-tui hermes-agent herm-tui

# Resolve the pnpm global locations robustly rather than hardcoding pnpm's
# internal layout. pnpm v11 may keep package dirs below hashed project dirs
# under global/<v>, while `pnpm root -g` returns only the aggregate root.
PNPM_GLOBAL_ROOT="$(pnpm root -g)"
PNPM_BIN="$(pnpm bin -g)"
PNPM_LIST_JSON="$(pnpm list -g --depth 0 --json)"

resolve_global_pkg_dir() {
  local pkg_name="$1"
  printf '%s' "$PNPM_LIST_JSON" | command node -e '
const fs = require("fs");
const pkgName = process.argv[1];
const data = JSON.parse(fs.readFileSync(0, "utf8"));
const deps = data && data[0] && data[0].dependencies || {};
const pkg = deps[pkgName];
if (!pkg || !pkg.path) process.exit(3);
process.stdout.write(pkg.path);
' "$pkg_name"
}

resolve_pkg_bin() {
  local pkg_dir="$1" bin_name="$2"
  command node -e '
const fs = require("fs"), path = require("path");
const [pkgDir, binName] = process.argv.slice(1);
const pkg = JSON.parse(fs.readFileSync(path.join(pkgDir, "package.json"), "utf8"));
const bin = pkg.bin;
let rel;
if (typeof bin === "string") rel = bin;
else if (bin && typeof bin === "object") rel = bin[binName] || Object.values(bin)[0];
if (!rel) process.exit(3);
process.stdout.write(path.resolve(pkgDir, rel));
' "$pkg_dir" "$bin_name"
}

HERMES_AGENT_DIR="$(resolve_global_pkg_dir hermes-agent)"
HERM_TUI_DIR="$(resolve_global_pkg_dir herm-tui)"

chmod +x \
  "$HERMES_AGENT_DIR/bin/hermes.js" \
  "$HERMES_AGENT_DIR/bin/hermes-agent.js" \
  "$HERM_TUI_DIR/src/index.tsx" \
  2>/dev/null || true

hermes_entry="$(resolve_pkg_bin "$HERMES_AGENT_DIR" hermes 2>/dev/null || true)"
[ -n "$hermes_entry" ] || hermes_entry="$HERMES_AGENT_DIR/bin/hermes.js"
hermes_agent_entry="$(resolve_pkg_bin "$HERMES_AGENT_DIR" hermes-agent 2>/dev/null || true)"
[ -n "$hermes_agent_entry" ] || hermes_agent_entry="$HERMES_AGENT_DIR/bin/hermes-agent.js"
herm_entry="$(resolve_pkg_bin "$HERM_TUI_DIR" herm 2>/dev/null || true)"
[ -n "$herm_entry" ] || herm_entry="$HERM_TUI_DIR/bin/herm.cjs"

# write_shim <name> <exec-token>...
# Emits $SHIM_DIR/<name>: exports the toolchain env, then exec's the given
# command. The FINAL token is the target file and must never equal the shim's
# own path (defensive guard against SHIM_DIR == PNPM_BIN self-exec recursion).
write_shim() {
  local name="$1"; shift
  local shim="$SHIM_DIR/$name"
  local args=("$@")
  local target="${args[${#args[@]}-1]}"
  if [ "$target" = "$shim" ]; then
    echo "ERROR: refusing to write self-referential shim: $shim -> $target" >&2
    exit 70
  fi
  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'export HERMES_TOOLCHAIN_HOME=%q\n' "$HERMES_TOOLCHAIN_HOME"
    printf 'export PNPM_HOME=%q\n' "$PNPM_HOME"
    printf 'export PATH=%q:%q:%q:"$PATH"\n' "$BUN_HOME/bin" "$PNPM_BIN" "$VENV/bin"
    printf 'exec'
    printf ' %q' "$@"
    printf ' "$@"\n'
  } > "$shim"
  chmod 0755 "$shim"
}

# pnpm may place its own global launchers in $SHIM_DIR (~/.local/bin). Replace
# them with env-setting shims that exec the package entrypoints directly, so the
# Hermes Python venv and Bun runtime are always on PATH even in non-login shells.
write_shim hermes       node "$hermes_entry"
write_shim hermes-agent node "$hermes_agent_entry"
write_shim herm         "$herm_entry"
write_shim hs "$SCRIPT_DIR/hs"
write_shim dream "$SCRIPT_DIR/dream"
write_shim agents "$SCRIPT_DIR/agents"
write_shim cos "$SCRIPT_DIR/cos"
write_shim cosw "$SCRIPT_DIR/cosw"
write_shim pm "$SCRIPT_DIR/pm"
write_shim pl "$SCRIPT_DIR/pl"

if [ "$SKIP_PRIVATE_SYNC" -eq 0 ]; then
  "$SCRIPT_DIR/private-sync"
fi

cat <<EOF
Hermes toolchain installed.

User-local shims:
  $SHIM_DIR/hermes
  $SHIM_DIR/hermes-agent
  $SHIM_DIR/herm
  $SHIM_DIR/hs
  $SHIM_DIR/dream
  $SHIM_DIR/agents
  $SHIM_DIR/cos
  $SHIM_DIR/cosw
  $SHIM_DIR/pm
  $SHIM_DIR/pl

Package entrypoints (exec'd by the shims above):
  hermes       -> node $hermes_entry
  hermes-agent -> node $hermes_agent_entry
  herm         -> $herm_entry
EOF
