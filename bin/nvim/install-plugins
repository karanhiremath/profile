#!/usr/bin/env bash
# Install neovim plugins using lazy.nvim

set -e

echo "Installing nvim plugins..."

# Get the script directory (where nvim config is)
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Copy marker file if it exists to config directory
if [ -f "${SCRIPT_DIR}/.use-old-lspconfig" ]; then
    echo "Detected older nvim version, will use compatible nvim-lspconfig..."
    mkdir -p "${HOME}/.config/nvim"
    cp "${SCRIPT_DIR}/.use-old-lspconfig" "${HOME}/.config/nvim/.use-old-lspconfig"
fi

# lazy.nvim auto-bootstraps via lua/kh/lazy.lua (clones itself on first run).
# Just run nvim headless to trigger the bootstrap + plugin install.
# nvim is provided by mise (shim on PATH).
if command -v nvim &>/dev/null; then
    NVIM="nvim"
else
    echo "ERROR: nvim not found. Run the nvim installer first: just nvim" >&2
    exit 1
fi

echo "Installing/updating plugins with lazy.nvim (using ${NVIM})..."
"$NVIM" --headless "+Lazy! sync" +qa

echo "✓ Nvim plugins installed successfully"
