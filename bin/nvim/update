#!/bin/bash

set -euo pipefail

shopt -s failglob

. "${PROFILE_DIR}"/bin/sh/shell_fns --source-only

app_name="nvim"

echo "Updating nvim..."

MACHINE="$(uname -s)"

if command -v mise >/dev/null 2>&1; then
    echo "Updating nvim via mise..."
    mise upgrade neovim
else
    case "${MACHINE}" in
        Darwin|Mac)
            # Fallback for a Homebrew-installed nvim (mise install failed path).
            if brew list neovim >/dev/null 2>&1; then
                echo "Updating nvim via Homebrew..."
                brew upgrade neovim
            else
                echo "mise not found and nvim not installed via Homebrew. Cannot update."
                exit 1
            fi
            ;;
        Linux|*)
            echo "mise not found. Cannot update nvim. Run: just mise"
            exit 1
            ;;
    esac
fi

# Update nvim plugins
echo "Updating nvim plugins..."
"${PROFILE_DIR}/bin/nvim/install-plugins"

echo "nvim update complete."
