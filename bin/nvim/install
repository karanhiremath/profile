#!/bin/bash

set -euo pipefail

shopt -s failglob

. "${PROFILE_DIR}/bin/sh/shell_fns" --source-only

touch "${HOME}/.netrc"
mkdir -p "${HOME}/.cache/nvim/undo"
mkdir -p "${HOME}/.config/nvim/"
ln -fns "${PROFILE_DIR}"/bin/nvim/init.lua "${HOME}"/.config/nvim/init.lua
ln -fns "${PROFILE_DIR}"/bin/nvim/lua "${HOME}"/.config/nvim/lua
ln -fns "${PROFILE_DIR}"/bin/nvim/after "${HOME}"/.config/nvim/after

app_name="nvim"

MACHINE="$(uname -s)"

install_messages "start" "$app_name"

# --- Skip if nvim is already installed and working (mise shim on PATH) ---
if command -v nvim >/dev/null 2>&1 && nvim --version >/dev/null 2>&1; then
    echo "✓ nvim already installed: $(nvim --version | head -1)"

    # Sync plugins (fast — lazy.nvim only installs missing ones)
    echo "Syncing plugins..."
    "${PROFILE_DIR}/bin/nvim/install-plugins"

    install_messages "end" "$app_name"
    exit 0
fi

# --- Fresh install via mise ---
# neovim is declared in config/mise/config.toml; `mise install neovim`
# provisions it and exposes the `nvim` shim on PATH.
install_nvim_mise() {
    if ! command -v mise >/dev/null 2>&1; then
        echo "mise not found; installing mise first..."
        "${PROFILE_DIR}/bin/mise/install"
    fi

    # The Linux mise installer lands in ~/.local/bin, which may not be on this
    # process's PATH yet (install.sh only wires it into ~/.zshrc).
    if ! command -v mise >/dev/null 2>&1 && [ -x "${HOME}/.local/bin/mise" ]; then
        export PATH="${HOME}/.local/bin:${PATH}"
    fi

    echo "Installing latest neovim via mise..."
    mise install neovim

    # Refresh command lookup so the freshly-installed shim resolves.
    hash -r 2>/dev/null || true

    command -v nvim >/dev/null 2>&1 && nvim --version >/dev/null 2>&1
}

if install_nvim_mise; then
    echo "✓ Neovim installed via mise: $(nvim --version | head -1)"
else
    case "${MACHINE}" in
        Darwin|Mac)
            echo "mise install failed; falling back to Homebrew..."
            brew install neovim
            ;;
        Linux|*)
            echo "ERROR: Failed to install neovim via mise." >&2
            exit 1
            ;;
    esac
fi

# Install plugins
echo "Installing nvim plugins..."
"${PROFILE_DIR}/bin/nvim/install-plugins"

install_messages "end" "$app_name"
