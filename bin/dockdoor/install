#!/bin/bash

set -euo pipefail

shopt -s failglob

# Set PROFILE_DIR and APP_BIN if not already set
if [ -z "${PROFILE_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROFILE_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

if [ -z "${APP_BIN:-}" ]; then
    export APP_BIN="${PROFILE_DIR}/bin"
fi

. "${APP_BIN}/sh/shell_fns" --source-only
. "${APP_BIN}/sh/brew_helper.sh"

app_name="dockdoor"

MACHINE="$(uname -s)"

# Check if already installed (macOS only)
if [[ "${MACHINE}" == "Darwin" ]] && [ -d "/Applications/DockDoor.app" ]; then
    echo "DockDoor already installed. Checking for updates..."
    ensure_brew_in_path || {
        echo "ERROR: Homebrew not found. Please install Homebrew first."
        exit 1
    }
    brew upgrade --cask dockdoor || echo "DockDoor is already up to date"
    exit 0
fi

install_messages "start" "$app_name"

case "${MACHINE}" in
    Darwin)
        echo "Installing DockDoor on Mac..."
        ensure_brew_in_path || {
            echo "ERROR: Homebrew not found. Please install Homebrew first."
            exit 1
        }
        brew install --cask dockdoor
        ;;
    Linux)
        echo "DockDoor is only available on macOS."
        echo "Skipping installation on Linux."
        exit 0
        ;;
    *)
        echo "Unsupported platform: ${MACHINE}"
        exit 1
        ;;
esac

install_messages "end" "$app_name"

echo ""
echo "DockDoor installed successfully!"
echo "Launch DockDoor from Applications and grant Accessibility permissions."
echo ""
