#!/usr/bin/env bash
set -euo pipefail

# claude-usage — Token usage tracker and cost estimator for Claude Code
# Parses ~/.claude session logs and stats to show spend, trends, and optimization tips.

CLAUDE_DIR="${HOME}/.claude"
STATS_FILE="${CLAUDE_DIR}/stats-cache.json"
PROJECTS_DIR="${CLAUDE_DIR}/projects"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OTEL_DIR="${SCRIPT_DIR}/otel"
OTEL_DATA_DIR="${HOME}/.local/share/claude-usage/otel"

# Pricing is defined in the Python blocks below (per 1M tokens, USD).
# Opus:  input=$15, output=$75, cache_read=$1.50, cache_write=$18.75
# Sonnet: input=$3, output=$15, cache_read=$0.30, cache_write=$3.75

usage() {
    cat <<EOF
claude-usage — Track Claude Code token spend and optimize usage

USAGE:
    claude-usage [command] [options]

COMMANDS:
    summary         Overall usage summary with cost estimate (default)
    daily           Day-by-day breakdown with costs
    sessions        Per-session breakdown (most expensive first)
    projects        Per-project/repo breakdown
    today           Today's usage so far
    week            This week's usage
    trends          Usage trends and patterns
    budget          Budget tracking against a monthly target
    optimize        Optimization recommendations
    export          Export data as CSV
    raw             Dump raw stats JSON
    otel-start      Start local OTEL collector (native, no containers)
    otel-stack      Start full observability stack (collector + Prometheus + Grafana)
    otel-stop       Stop OTEL collector or full stack
    otel-emit       Emit session data to OTEL collector
    otel-status     Show OTEL stack status

OPTIONS:
    -d, --days N        Show last N days (default: 30)
    -m, --model MODEL   Filter by model (opus, sonnet)
    -b, --budget USD    Monthly budget in USD (default: \$500)
    -p, --project NAME  Filter by project slug
    --no-color          Disable color output
    -h, --help          Show this help

EXAMPLES:
    claude-usage                    # Summary
    claude-usage daily -d 7         # Last 7 days
    claude-usage budget -b 300      # Track against \$300/mo budget
    claude-usage sessions -d 1      # Today's sessions
    claude-usage otel-start           # Start local OTEL collector
    claude-usage otel-stack           # Full stack with Grafana at localhost:3033
    claude-usage otel-emit            # Push session data to collector
    claude-usage otel-emit --dry-run  # Preview what would be emitted
    claude-usage projects           # Per-repo breakdown
    claude-usage optimize           # Get optimization tips
    claude-usage export > usage.csv # Export to CSV
EOF
}

