cmd_budget() {
    local budget="${BUDGET:-500}"
    local days="${DAYS:-30}"

    echo ""
    color "$BOLD" "Budget Tracker"
    echo ""
    color "$DIM" "(monthly budget: \$$budget)"
    echo ""
    echo ""

    parse_sessions "$days" "$PROJECT_FILTER" | python3 -c "
import json, sys, datetime
from collections import defaultdict

budget = $budget

PRICES = {
    'opus':   {'input': 15.00, 'output': 75.00, 'cache_read': 1.50, 'cache_write': 18.75},
    'sonnet': {'input': 3.00,  'output': 15.00, 'cache_read': 0.30, 'cache_write': 3.75},
}

def tier(m):
    return 'opus' if 'opus' in m else 'sonnet'

def cost(t, i, o, cr, cw):
    p = PRICES[t]
    return (i*p['input'] + o*p['output'] + cr*p['cache_read'] + cw*p['cache_write']) / 1_000_000

today = datetime.date.today()
month_start = today.replace(day=1)
days_in_month = 30
days_elapsed = (today - month_start).days + 1
days_remaining = max(days_in_month - days_elapsed, 0)

monthly_cost = 0
daily_costs = defaultdict(float)

for line in sys.stdin:
    d = json.loads(line)
    if d['date'] < month_start.isoformat():
        continue
    t = tier(d['model'])
    c = cost(t, d['input'], d['output'], d['cache_read'], d['cache_write'])
    monthly_cost += c
    daily_costs[d['date']] += c

used_pct = monthly_cost / budget * 100
remaining = budget - monthly_cost
daily_budget_remaining = remaining / max(days_remaining, 1)

# Progress bar
bar_width = 40
filled = int(used_pct / 100 * bar_width)
bar = '█' * min(filled, bar_width) + '░' * max(bar_width - filled, 0)

if used_pct > 90:
    status = '🔴 CRITICAL'
elif used_pct > 75:
    status = '🟡 WARNING'
elif used_pct > 50:
    status = '🟠 MODERATE'
else:
    status = '🟢 ON TRACK'

print(f'  Status: {status}')
print(f'  [{bar}] {used_pct:.1f}%')
print()
print(f'  Budget:          \${budget:>10.2f}')
print(f'  Spent (MTD):     \${monthly_cost:>10.2f}')
print(f'  Remaining:       \${remaining:>10.2f}')
print()
print(f'  Days elapsed:    {days_elapsed:>10}')
print(f'  Days remaining:  {days_remaining:>10}')
print(f'  Daily allowance: \${daily_budget_remaining:>10.2f}/day')
print()

# Projection
active_days = len(daily_costs)
if active_days > 0:
    avg_daily = monthly_cost / active_days
    projected = avg_daily * days_in_month
    over_under = projected - budget

    print(f'  PROJECTION')
    print(f'  Avg daily spend: \${avg_daily:>10.2f}')
    print(f'  Month-end proj:  \${projected:>10.2f}')
    if over_under > 0:
        print(f'  ⚠️  Projected OVER budget by \${over_under:.2f}')
        safe_daily = remaining / max(days_remaining, 1)
        print(f'  To stay on budget: \${safe_daily:.2f}/day max for remaining {days_remaining} days')
    else:
        print(f'  ✅ Projected UNDER budget by \${abs(over_under):.2f}')
"
}

cmd_optimize() {
    local days="${DAYS:-14}"
    echo ""
    color "$BOLD" "Optimization Recommendations"
    echo ""
    echo ""

    parse_sessions "$days" "$PROJECT_FILTER" | python3 -c "
import json, sys
from collections import defaultdict

PRICES = {
    'opus':   {'input': 15.00, 'output': 75.00, 'cache_read': 1.50, 'cache_write': 18.75},
    'sonnet': {'input': 3.00,  'output': 15.00, 'cache_read': 0.30, 'cache_write': 3.75},
}

def tier(m):
    return 'opus' if 'opus' in m else 'sonnet'

def cost(t, i, o, cr, cw):
    p = PRICES[t]
    return (i*p['input'] + o*p['output'] + cr*p['cache_read'] + cw*p['cache_write']) / 1_000_000

# Gather stats
total = {'input':0, 'output':0, 'cache_read':0, 'cache_write':0, 'msgs':0}
by_model = defaultdict(lambda: {'cost':0, 'msgs':0, 'output':0})
sessions = defaultdict(lambda: {'cost':0, 'msgs':0, 'output':0, 'cache_read':0, 'total_input':0})
short_sessions = 0

for line in sys.stdin:
    d = json.loads(line)
    t = tier(d['model'])
    c = cost(t, d['input'], d['output'], d['cache_read'], d['cache_write'])
    total['input'] += d['input']
    total['output'] += d['output']
    total['cache_read'] += d['cache_read']
    total['cache_write'] += d['cache_write']
    total['msgs'] += 1
    by_model[t]['cost'] += c
    by_model[t]['msgs'] += 1
    by_model[t]['output'] += d['output']
    s = sessions[d['session']]
    s['cost'] += c
    s['msgs'] += 1
    s['output'] += d['output']
    s['cache_read'] += d['cache_read']
    s['total_input'] += d['cache_read'] + d['cache_write'] + d['input']

total_cost = sum(v['cost'] for v in by_model.values())
recs = []

# 1. Model mix
opus_cost = by_model.get('opus', {}).get('cost', 0)
opus_share = opus_cost / max(total_cost, 0.01) * 100
if opus_share > 80:
    sonnet_equiv = opus_cost * (15/75)  # rough output-dominated estimate
    savings = opus_cost - sonnet_equiv
    recs.append({
        'priority': '🔴 HIGH',
        'title': 'Switch exploration/research to Sonnet',
        'detail': f'Opus is {opus_share:.0f}% of spend (\${opus_cost:.2f}). Using Sonnet for exploration could save ~\${savings:.2f}.',
        'action': 'Use --model sonnet for code review, exploration, and Q&A. Reserve Opus for complex implementation.',
        'savings': savings,
    })

# 2. Cache efficiency
cache_total = total['cache_read'] + total['cache_write'] + total['input']
cache_pct = total['cache_read'] / max(cache_total, 1) * 100
if cache_pct < 80:
    recs.append({
        'priority': '🟡 MEDIUM',
        'title': 'Improve cache hit rate',
        'detail': f'Cache hit rate is {cache_pct:.1f}%. Target >85%.',
        'action': 'Use longer sessions instead of many short ones. Use --continue to resume. Avoid switching repos mid-task.',
        'savings': 0,
    })

# 3. Short sessions (< 5 messages)
for sid, sv in sessions.items():
    if sv['msgs'] < 5:
        short_sessions += 1
if short_sessions > len(sessions) * 0.3:
    recs.append({
        'priority': '🟡 MEDIUM',
        'title': 'Consolidate short sessions',
        'detail': f'{short_sessions}/{len(sessions)} sessions have <5 messages. Each new session pays cache warmup cost.',
        'action': 'Batch related tasks. Use /continue. Fewer, longer sessions = better cache = lower cost.',
        'savings': 0,
    })

# 4. Output token dominance
output_cost = total['output'] * 75 / 1_000_000  # opus pricing
output_share = output_cost / max(total_cost, 0.01) * 100
if output_share > 50:
    recs.append({
        'priority': '🟡 MEDIUM',
        'title': 'Reduce output token volume',
        'detail': f'Output tokens are ~{output_share:.0f}% of cost.',
        'action': 'Be specific in prompts. Ask for diffs not full files. Use \"be concise\" in CLAUDE.md system prompt.',
        'savings': 0,
    })

# 5. Worktree sprawl
worktree_sessions = [s for s in sessions.keys() if 'worktree' in s.lower()]
if len(sessions) > 10:
    recs.append({
        'priority': '🟢 LOW',
        'title': 'Review session count',
        'detail': f'{len(sessions)} sessions in this period. Each session warms up context independently.',
        'action': 'Use --continue and --name to maintain context across sessions on the same task.',
        'savings': 0,
    })

# 6. Effort level
recs.append({
    'priority': '🟢 TIP',
    'title': 'Use --effort for routine tasks',
    'detail': 'Claude Code supports --effort low|medium|high|max.',
    'action': 'Use low effort for simple edits, git ops, file lookups. Save high/max for complex implementations.',
    'savings': 0,
})

# 7. Max budget flag
recs.append({
    'priority': '🟢 TIP',
    'title': 'Set --max-budget-usd for automated runs',
    'detail': 'Prevents runaway costs in --print mode and agent spawning.',
    'action': 'Add --max-budget-usd 5 for scripted/automated Claude Code invocations.',
    'savings': 0,
})

if not recs:
    print('  ✅ No major optimization opportunities found!')
else:
    for i, r in enumerate(recs, 1):
        print(f'  {r[\"priority\"]} #{i}: {r[\"title\"]}')
        print(f'     {r[\"detail\"]}')
        print(f'     → {r[\"action\"]}')
        if r['savings'] > 0:
            print(f'     💰 Potential savings: ~\${r[\"savings\"]:.2f}')
        print()

# Summary
print(f'  QUICK WINS:')
print(f'    • Add to settings.json: \"model\": \"sonnet\" for default, override with --model opus when needed')
print(f'    • Add to CLAUDE.md: \"Be concise. Show diffs not full files. Minimize output tokens.\"')
print(f'    • Use claude --continue instead of starting new sessions')
print(f'    • Use claude --effort low for simple tasks')
"
}

