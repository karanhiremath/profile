import json, sys
from collections import defaultdict
import datetime

PRICES = {
    'opus':   {'input': 15.00, 'output': 75.00, 'cache_read': 1.50, 'cache_write': 18.75},
    'sonnet': {'input': 3.00,  'output': 15.00, 'cache_read': 0.30, 'cache_write': 3.75},
}

def tier(m):
    return 'opus' if 'opus' in m else 'sonnet'

def cost(t, i, o, cr, cw):
    p = PRICES[t]
    return (i*p['input'] + o*p['output'] + cr*p['cache_read'] + cw*p['cache_write']) / 1_000_000

daily = defaultdict(lambda: {'cost':0,'output':0,'cache_read':0,'cache_write':0,'input':0,'msgs':0})
hourly = defaultdict(float)
model_cost = defaultdict(float)
weekday = defaultdict(lambda: {'cost':0,'days':set()})

for line in sys.stdin:
    d = json.loads(line)
    t = tier(d['model'])
    c = cost(t, d['input'], d['output'], d['cache_read'], d['cache_write'])
    day = daily[d['date']]
    day['cost'] += c
    day['output'] += d['output']
    day['cache_read'] += d['cache_read']
    day['cache_write'] += d['cache_write']
    day['input'] += d['input']
    day['msgs'] += 1
    model_cost[t] += c

    # Hour of day
    try:
        hour = int(d['timestamp'][11:13])
        hourly[hour] += c
    except:
        pass

    # Day of week
    try:
        dt = datetime.date.fromisoformat(d['date'])
        wd = dt.strftime('%A')
        weekday[wd]['cost'] += c
        weekday[wd]['days'].add(d['date'])
    except:
        pass

dates = sorted(daily.keys())
if len(dates) < 2:
    print('  Not enough data for trends')
    sys.exit(0)

costs = [daily[d]['cost'] for d in dates]
avg = sum(costs) / len(costs)

# Week-over-week
mid = len(dates) // 2
first_half = sum(costs[:mid]) / max(mid, 1)
second_half = sum(costs[mid:]) / max(len(costs) - mid, 1)
trend_pct = ((second_half - first_half) / max(first_half, 0.01)) * 100

print('  COST TREND')
if trend_pct > 10:
    print(f'  📈 Spending is UP {trend_pct:.0f}% (recent vs earlier half)')
elif trend_pct < -10:
    print(f'  📉 Spending is DOWN {abs(trend_pct):.0f}% (recent vs earlier half)')
else:
    print(f'  ➡️  Spending is STABLE ({trend_pct:+.0f}%)')
print(f'  Average: \${avg:.2f}/day')
print()

# Cache efficiency trend
cache_data = [(d, daily[d]['cache_read'] / max(daily[d]['cache_read']+daily[d]['cache_write']+daily[d]['input'], 1) * 100) for d in dates]
avg_cache = sum(c for _, c in cache_data) / len(cache_data)
print(f'  CACHE EFFICIENCY')
print(f'  Average cache hit rate: {avg_cache:.1f}%')
if avg_cache < 80:
    print(f'  ⚠️  Below 80% — consider longer sessions to build cache')
else:
    print(f'  ✅ Good cache utilization')
print()

# Output token ratio (this is where cost really lives for opus)
total_output = sum(daily[d]['output'] for d in dates)
total_cost = sum(costs)
output_cost_share = sum(daily[d]['output'] * 75 / 1_000_000 for d in dates) / max(total_cost, 0.01) * 100
print(f'  OUTPUT TOKENS')
print(f'  Output tokens are {output_cost_share:.0f}% of your total cost')
if output_cost_share > 60:
