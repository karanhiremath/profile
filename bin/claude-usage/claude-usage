# --- Data extraction ---

get_stats() {
    if [[ ! -f "$STATS_FILE" ]]; then
        echo "No stats cache found. Run a Claude Code session first." >&2
        exit 1
    fi
    cat "$STATS_FILE"
}

# Parse all JSONL session files and extract token usage per message
parse_sessions() {
    local days="${1:-30}" project_filter="${2:-}"

    local cutoff_date
    cutoff_date=$(date -v-${days}d +%Y-%m-%d 2>/dev/null || date -d "$days days ago" +%Y-%m-%d 2>/dev/null)

    local find_path="$PROJECTS_DIR"
    if [[ -n "$project_filter" ]]; then
        find_path=$(find "$PROJECTS_DIR" -maxdepth 1 -type d -name "*${project_filter}*" | head -1)
        if [[ -z "$find_path" ]]; then
            echo "No project matching '$project_filter'" >&2
            exit 1
        fi
    fi

    find "$find_path" -name "*.jsonl" -print0 2>/dev/null | xargs -0 python3 -c "
import json, sys, os
from datetime import datetime, timezone
from collections import defaultdict

cutoff = '$cutoff_date'
results = []

for filepath in sys.argv[1:]:
    # Extract project from path
    parts = filepath.split('/projects/')
    if len(parts) < 2:
        continue
    project_slug = parts[1].split('/')[0]
    session_id = os.path.basename(filepath).replace('.jsonl', '')

    try:
        with open(filepath) as f:
            for line in f:
                try:
                    d = json.loads(line.strip())
                except:
                    continue

                if d.get('type') != 'assistant':
                    continue
                msg = d.get('message', {})
                usage = msg.get('usage', {})
                if not usage:
                    continue

                ts = d.get('timestamp', '')
                if not ts:
                    continue
                date = ts[:10]
                if date < cutoff:
                    continue

                model = msg.get('model', 'unknown')
                input_t = usage.get('input_tokens', 0)
                output_t = usage.get('output_tokens', 0)
                cache_read = usage.get('cache_read_input_tokens', 0)
                cache_write = usage.get('cache_creation_input_tokens', 0)

                results.append({
                    'date': date,
                    'timestamp': ts,
                    'model': model,
                    'session': session_id,
                    'project': project_slug,
                    'input': input_t,
                    'output': output_t,
                    'cache_read': cache_read,
                    'cache_write': cache_write,
                })
    except Exception as e:
        pass

for r in results:
    print(json.dumps(r))
" 2>/dev/null
}

