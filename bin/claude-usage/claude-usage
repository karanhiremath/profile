import json, sys
from collections import defaultdict

PRICES = {
    'opus':   {'input': 15.00, 'output': 75.00, 'cache_read': 1.50, 'cache_write': 18.75},
    'sonnet': {'input': 3.00,  'output': 15.00, 'cache_read': 0.30, 'cache_write': 3.75},
}

def tier(model):
    if 'opus' in model: return 'opus'
    return 'sonnet'

def cost(t, i, o, cr, cw):
    p = PRICES[t]
    return (i*p['input'] + o*p['output'] + cr*p['cache_read'] + cw*p['cache_write']) / 1_000_000

totals = defaultdict(lambda: {'input':0,'output':0,'cache_read':0,'cache_write':0,'cost':0,'msgs':0})
daily = defaultdict(float)
sessions = set()
projects = defaultdict(float)

for line in sys.stdin:
    d = json.loads(line)
    t = tier(d['model'])
    c = cost(t, d['input'], d['output'], d['cache_read'], d['cache_write'])

    totals[t]['input'] += d['input']
    totals[t]['output'] += d['output']
    totals[t]['cache_read'] += d['cache_read']
    totals[t]['cache_write'] += d['cache_write']
    totals[t]['cost'] += c
    totals[t]['msgs'] += 1

    daily[d['date']] += c
    sessions.add(d['session'])
    projects[d['project']] += c

total_cost = sum(v['cost'] for v in totals.values())
total_msgs = sum(v['msgs'] for v in totals.values())
active_days = len(daily)
avg_daily = total_cost / max(active_days, 1)

print(f'  Total estimated cost:  \${total_cost:>10.2f}')
print(f'  Active days:           {active_days:>10}')
print(f'  Avg cost/active day:   \${avg_daily:>10.2f}')
print(f'  Total sessions:        {len(sessions):>10}')
print(f'  Total API messages:    {total_msgs:>10}')
print()

for t in ['opus', 'sonnet']:
    if t not in totals or totals[t]['msgs'] == 0:
        continue
    v = totals[t]
    print(f'  {t.upper()}:')
    print(f'    Cost:        \${v[\"cost\"]:>10.2f}  ({v[\"cost\"]/max(total_cost,0.01)*100:.0f}% of total)')
    print(f'    Input:       {v[\"input\"]:>10,} tokens')
    print(f'    Output:      {v[\"output\"]:>10,} tokens')
    print(f'    Cache read:  {v[\"cache_read\"]:>10,} tokens')
    print(f'    Cache write: {v[\"cache_write\"]:>10,} tokens')
    cache_hit = v['cache_read'] / max(v['cache_read']+v['cache_write']+v['input'], 1) * 100
    print(f'    Cache hit:   {cache_hit:>9.1f}%')
    print()

if projects:
    print('  Top projects by cost:')
    for proj, c in sorted(projects.items(), key=lambda x: -x[1])[:5]:
        short = proj.replace('-Users-karanhiremath-src-','').replace('-Users-karanhiremath-','~/')
        bar = '█' * max(1, int(c / max(total_cost,0.01) * 30))
        print(f'    {short:40s} \${c:>8.2f}  {bar}')
    print()

# Projection
if active_days > 0:
    import datetime
    today = datetime.date.today()
    days_in_month = 30
    days_left = days_in_month - today.day
    projected = avg_daily * days_in_month
    print(f'  Monthly projection:    \${projected:>10.2f}  (at \${avg_daily:.2f}/day)')
    print(f'  Remaining this month:  \${avg_daily * max(days_left, 0):>10.2f}  ({max(days_left,0)} days)')
"
}

