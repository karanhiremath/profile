NC='\033[0m'

NO_COLOR=false

color() {
    if $NO_COLOR; then echo -n "$2"; else echo -ne "$1$2${NC}"; fi
}

fmt_tokens() {
    local n=$1
    if (( n >= 1000000 )); then
        printf "%.1fM" "$(echo "$n / 1000000" | bc -l)"
    elif (( n >= 1000 )); then
        printf "%.1fK" "$(echo "$n / 1000" | bc -l)"
    else
        printf "%d" "$n"
    fi
}

fmt_cost() {
    printf "\$%.2f" "$1"
}

model_tier() {
    local model="$1"
    if [[ "$model" == *"opus"* ]]; then echo "opus"
    elif [[ "$model" == *"sonnet"* ]]; then echo "sonnet"
    else echo "sonnet"  # default
    fi
