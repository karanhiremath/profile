# --- OTEL Stack Commands ---

cmd_otel_start() {
    echo ""
    color "$BOLD" "Starting Local OTEL Collector"
    echo ""
    echo ""

    mkdir -p "$OTEL_DATA_DIR"

    local PID_FILE="${OTEL_DATA_DIR}/.collector.pid"
    local LOG_FILE="${OTEL_DATA_DIR}/.collector.log"

    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "  OTEL collector already running (PID $(cat "$PID_FILE"))"
        return 0
    fi

    if ! command -v otelcol-contrib &>/dev/null; then
        echo "  Error: otelcol-contrib not found." >&2
        echo "  Install with: brew install open-telemetry/opentelemetry-collector-releases/otelcol-contrib" >&2
        return 1
    fi

    export OTEL_DATA_DIR
    nohup otelcol-contrib --config "${OTEL_DIR}/collector-config.yaml" > "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    echo "  ✓ OTEL collector started (PID $!)"
    echo "  Traces → ${OTEL_DATA_DIR}/traces.jsonl"
    echo "  Metrics → ${OTEL_DATA_DIR}/metrics.jsonl"
    echo "  Prometheus → http://localhost:8889/metrics"
    echo ""
    echo "  Set in your shell:"
    echo "    export OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317"
}

cmd_otel_stack() {
    echo ""
    color "$BOLD" "Starting Full Observability Stack"
    echo ""
    echo ""

    if ! command -v podman &>/dev/null; then
        echo "  Error: podman required for full stack." >&2
        echo "  Install with: brew install podman" >&2
        return 1
    fi

    mkdir -p "$OTEL_DATA_DIR"

    local COMPOSE_CMD="podman-compose"
    if ! command -v podman-compose &>/dev/null; then
        COMPOSE_CMD="podman compose"
    fi

    cd "${OTEL_DIR}"
    $COMPOSE_CMD -f podman-compose.yaml up -d

    echo ""
    echo "  ✓ Stack started:"
    echo "    OTEL Collector  → localhost:4317 (gRPC) / localhost:4318 (HTTP)"
    echo "    Prometheus      → http://localhost:9090"
    echo "    Grafana         → http://localhost:3033 (admin/admin)"
    echo ""
    echo "  Emit session data:"
    echo "    claude-usage otel-emit"
    echo ""
    echo "  Stop with:"
    echo "    claude-usage otel-stop --stack"
}

cmd_otel_stop() {
    echo ""
    color "$BOLD" "Stopping OTEL"
    echo ""
    echo ""

    # Stop native collector
    local PID_FILE="${OTEL_DATA_DIR}/.collector.pid"
    if [[ -f "$PID_FILE" ]]; then
        local PID
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID"
            echo "  ✓ OTEL collector stopped (PID $PID)"
        else
            echo "  Collector not running (stale PID)"
        fi
        rm -f "$PID_FILE"
    fi

    # Stop container stack if --stack flag or containers running
    if [[ "${OTEL_STOP_STACK:-false}" == "true" ]]; then
        local COMPOSE_CMD="podman-compose"
        if ! command -v podman-compose &>/dev/null; then
            COMPOSE_CMD="podman compose"
        fi
        cd "${OTEL_DIR}" 2>/dev/null && $COMPOSE_CMD -f podman-compose.yaml down 2>/dev/null && \
            echo "  ✓ Container stack stopped" || \
            echo "  No container stack running"
    fi
}

cmd_otel_emit() {
    echo ""
    color "$BOLD" "Emitting Session Data to OTEL"
    echo ""
    echo ""

    local emitter="${SCRIPT_DIR}/claude-usage-emitter"
    local days="${DAYS:-7}"
    local extra_args=()

    if [[ "${DRY_RUN:-false}" == "true" ]]; then
        extra_args+=(--dry-run)
    fi

    python3 "$emitter" --days "$days" "${extra_args[@]}"
}

cmd_otel_status() {
    echo ""
    color "$BOLD" "OTEL Stack Status"
    echo ""
    echo ""

    # Native collector
    local PID_FILE="${OTEL_DATA_DIR}/.collector.pid"
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "  Native collector:  ✅ running (PID $(cat "$PID_FILE"))"
    else
        echo "  Native collector:  ⬚ stopped"
    fi

    # Container stack
    if podman ps --format '{{.Names}}' 2>/dev/null | grep -q "otel-collector"; then
        echo "  Container stack:   ✅ running"
        podman ps --filter name=otel- --format "    {{.Names}}: {{.Status}}" 2>/dev/null
    else
        echo "  Container stack:   ⬚ stopped"
    fi

    # Data files
    echo ""
    echo "  Data directory: ${OTEL_DATA_DIR}"
    if [[ -d "$OTEL_DATA_DIR" ]]; then
        for f in traces.jsonl metrics.jsonl; do
            if [[ -f "${OTEL_DATA_DIR}/$f" ]]; then
                local sz
                sz=$(du -sh "${OTEL_DATA_DIR}/$f" 2>/dev/null | cut -f1)
                local lines
                lines=$(wc -l < "${OTEL_DATA_DIR}/$f" 2>/dev/null || echo 0)
                echo "    $f: ${sz} (${lines} records)"
            fi
        done
    else
        echo "    (not created yet — run otel-start first)"
    fi

    # Emitter state
    local state_file="${HOME}/.claude/.otel-emitter-state.json"
    if [[ -f "$state_file" ]]; then
        local file_count
        file_count=$(python3 -c "import json; d=json.load(open('$state_file')); print(len(d.get('last_processed',{})))" 2>/dev/null || echo "?")
        echo ""
        echo "  Emitter: ${file_count} session files tracked"
    fi

    # Quick endpoint checks
    echo ""
    echo "  Endpoints:"
    for port_name in "4317:OTLP-gRPC" "4318:OTLP-HTTP" "8889:Prometheus" "9090:Prometheus-UI" "3033:Grafana"; do
        local port="${port_name%%:*}"
        local name="${port_name##*:}"
        if nc -z localhost "$port" 2>/dev/null; then
            echo "    ${name} (${port}): ✅"
        else
            echo "    ${name} (${port}): ⬚"
        fi
    done
}

# --- Main ---

COMMAND="${1:-summary}"
shift 2>/dev/null || true

DAYS=30
BUDGET=500
PROJECT_FILTER=""
MODEL_FILTER=""

DRY_RUN=false
OTEL_STOP_STACK=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--days) DAYS="$2"; shift 2 ;;
        -b|--budget) BUDGET="$2"; shift 2 ;;
        -p|--project) PROJECT_FILTER="$2"; shift 2 ;;
        -m|--model) MODEL_FILTER="$2"; shift 2 ;;
        --no-color) NO_COLOR=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --stack) OTEL_STOP_STACK=true; shift ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
done

case "$COMMAND" in
    summary)     cmd_summary ;;
    daily)       cmd_daily ;;
    sessions)    cmd_sessions ;;
    projects)    cmd_projects ;;
    today)       cmd_today ;;
    week)        cmd_week ;;
    trends)      cmd_trends ;;
    budget)      cmd_budget ;;
    optimize)    cmd_optimize ;;
    export)      cmd_export ;;
    raw)         cmd_raw ;;
    otel-start)  cmd_otel_start ;;
    otel-stack)  cmd_otel_stack ;;
    otel-stop)   cmd_otel_stop ;;
    otel-emit)   cmd_otel_emit ;;
    otel-status) cmd_otel_status ;;
    -h|--help|help) usage ;;
    *) echo "Unknown command: $COMMAND"; usage; exit 1 ;;
esac
