"""claude-usage-emitter — Parse Claude Code session logs and emit OTEL metrics.

Reads ~/.claude session JSONL files and pushes structured metrics to an OTEL
collector. Run as a cron job or one-shot after sessions.

Usage:
    claude-usage-emitter [--endpoint URL] [--days N] [--dry-run] [--help]

Run with: uv run claude-usage-emitter [args]
Dependencies are declared inline via PEP 723 — uv resolves them automatically.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
from collections import defaultdict
from datetime import datetime, timedelta, timezone
from pathlib import Path

# Pricing per 1M tokens
PRICES = {
    "opus":   {"input": 15.00, "output": 75.00, "cache_read": 1.50, "cache_write": 18.75},
    "sonnet": {"input": 3.00,  "output": 15.00, "cache_read": 0.30, "cache_write": 3.75},
}

CLAUDE_DIR = Path.home() / ".claude"
PROJECTS_DIR = CLAUDE_DIR / "projects"
STATE_FILE = CLAUDE_DIR / ".otel-emitter-state.json"


def model_tier(model: str) -> str:
    if "opus" in model:
        return "opus"
    return "sonnet"


def calc_cost(tier: str, input_t: int, output_t: int, cache_read: int, cache_write: int) -> float:
    p = PRICES[tier]
    return (input_t * p["input"] + output_t * p["output"] +
            cache_read * p["cache_read"] + cache_write * p["cache_write"]) / 1_000_000


def project_short_name(slug: str) -> str:
    return (slug
            .replace("-Users-karanhiremath-src-", "")
            .replace("-Users-karanhiremath-", "~/"))


def load_state() -> dict:
    if STATE_FILE.exists():
        return json.loads(STATE_FILE.read_text())
    return {"last_processed": {}}


def save_state(state: dict):
    STATE_FILE.write_text(json.dumps(state, indent=2))


def parse_sessions(days: int, state: dict) -> list[dict]:
    cutoff = (datetime.now(timezone.utc) - timedelta(days=days)).isoformat()
    last_processed = state.get("last_processed", {})
    records = []

    for jsonl_file in PROJECTS_DIR.rglob("*.jsonl"):
        file_key = str(jsonl_file)
        last_ts = last_processed.get(file_key, "")

        project_slug = str(jsonl_file.relative_to(PROJECTS_DIR)).split("/")[0]
        session_id = jsonl_file.stem

        try:
            with open(jsonl_file) as f:
                for line in f:
                    try:
                        d = json.loads(line.strip())
                    except json.JSONDecodeError:
                        continue

                    if d.get("type") != "assistant":
                        continue
                    msg = d.get("message", {})
                    usage = msg.get("usage", {})
                    if not usage:
                        continue

                    ts = d.get("timestamp", "")
                    if not ts or ts < cutoff:
                        continue
                    if ts <= last_ts:
                        continue

                    model = msg.get("model", "unknown")
                    tier = model_tier(model)

                    rec = {
                        "timestamp": ts,
                        "model": model,
                        "tier": tier,
                        "session": session_id,
                        "project": project_short_name(project_slug),
                        "project_slug": project_slug,
                        "input": usage.get("input_tokens", 0),
                        "output": usage.get("output_tokens", 0),
                        "cache_read": usage.get("cache_read_input_tokens", 0),
                        "cache_write": usage.get("cache_creation_input_tokens", 0),
                    }
                    rec["cost"] = calc_cost(tier, rec["input"], rec["output"],
                                           rec["cache_read"], rec["cache_write"])
                    records.append(rec)

                    if ts > last_processed.get(file_key, ""):
                        last_processed[file_key] = ts
        except Exception:
            continue

    state["last_processed"] = last_processed
    return records


def emit_otel(records: list[dict], endpoint: str):
    """Emit records as OTEL metrics via the Python SDK."""
    from opentelemetry import metrics
    from opentelemetry.sdk.metrics import MeterProvider
    from opentelemetry.sdk.metrics.export import PeriodicExportingMetricReader
    from opentelemetry.exporter.otlp.proto.grpc.metric_exporter import OTLPMetricExporter
    from opentelemetry.sdk.resources import Resource

    resource = Resource.create({
        "service.name": "claude-usage",
        "service.version": "1.0.0",
    })

    exporter = OTLPMetricExporter(endpoint=endpoint, insecure=True)
    reader = PeriodicExportingMetricReader(exporter, export_interval_millis=5000)
    provider = MeterProvider(resource=resource, metric_readers=[reader])
    metrics.set_meter_provider(provider)

    meter = metrics.get_meter("claude-usage")

    # Counters
    cost_counter = meter.create_counter(
        "session.cost_usd",
        unit="USD",
        description="Estimated cost in USD",
    )
    input_counter = meter.create_counter(
        "session.input_tokens",
        unit="tokens",
        description="Input tokens consumed",
    )
    output_counter = meter.create_counter(
        "session.output_tokens",
        unit="tokens",
        description="Output tokens generated",
    )
    cache_read_counter = meter.create_counter(
        "session.cache_read_tokens",
        unit="tokens",
        description="Cache read tokens",
    )
    cache_write_counter = meter.create_counter(
        "session.cache_write_tokens",
        unit="tokens",
        description="Cache write (creation) tokens",
    )
    message_counter = meter.create_counter(
        "session.messages",
        unit="messages",
        description="API messages sent",
    )

    # Aggregate by session+model for batch emission
    by_key = defaultdict(lambda: {
        "cost": 0, "input": 0, "output": 0,
        "cache_read": 0, "cache_write": 0, "messages": 0
    })

    for rec in records:
        key = (rec["project"], rec["model"], rec["session"][:8])
        agg = by_key[key]
        agg["cost"] += rec["cost"]
        agg["input"] += rec["input"]
        agg["output"] += rec["output"]
        agg["cache_read"] += rec["cache_read"]
        agg["cache_write"] += rec["cache_write"]
        agg["messages"] += 1

    for (project, model, session), agg in by_key.items():
        attrs = {"model": model, "project": project, "session": session}
        cost_counter.add(agg["cost"], attrs)
        input_counter.add(agg["input"], attrs)
        output_counter.add(agg["output"], attrs)
        cache_read_counter.add(agg["cache_read"], attrs)
        cache_write_counter.add(agg["cache_write"], attrs)
        message_counter.add(agg["messages"], attrs)

    # Force flush
    provider.force_flush(timeout_millis=10000)
    provider.shutdown()


def print_dry_run(records: list[dict]):
    """Print what would be emitted."""
    by_project = defaultdict(lambda: {"cost": 0, "msgs": 0, "output": 0})
    for rec in records:
        p = by_project[rec["project"]]
        p["cost"] += rec["cost"]
        p["msgs"] += 1
        p["output"] += rec["output"]

    total = sum(v["cost"] for v in by_project.values())
    total_msgs = sum(v["msgs"] for v in by_project.values())

    print(f"[DRY RUN] Would emit {len(records)} records ({total_msgs} messages)")
    print(f"[DRY RUN] Total estimated cost: ${total:.2f}")
    print()
    for proj, v in sorted(by_project.items(), key=lambda x: -x[1]["cost"]):
        print(f"  {proj:<40} ${v['cost']:>8.2f}  {v['msgs']:>5} msgs")


def main():
    parser = argparse.ArgumentParser(description=__doc__,
                                     formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--endpoint", default="localhost:4317",
                        help="OTEL collector gRPC endpoint (default: localhost:4317)")
    parser.add_argument("--days", type=int, default=7,
                        help="Process records from last N days (default: 7)")
    parser.add_argument("--dry-run", action="store_true",
                        help="Print what would be emitted without sending")
    parser.add_argument("--full", action="store_true",
                        help="Ignore state file and re-process all records")
    args = parser.parse_args()

    state = {} if args.full else load_state()
    records = parse_sessions(args.days, state)

    if not records:
        print("No new records to emit.")
        return

    if args.dry_run:
        print_dry_run(records)
    else:
        print(f"Emitting {len(records)} records to {args.endpoint}...")
        emit_otel(records, args.endpoint)
        save_state(state)
        print(f"Done. Emitted {len(records)} records.")


if __name__ == "__main__":
    main()
