{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Estimated Daily Cost ($)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(claude_session_cost_usd_total[1d])) * 86400",
          "legendFormat": "Daily Cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Output Tokens (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(claude_session_output_tokens_total[5m])) * 60",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "title": "Cache Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(claude_session_cache_read_tokens_total) / (sum(claude_session_cache_read_tokens_total) + sum(claude_session_cache_write_tokens_total) + sum(claude_session_input_tokens_total)) * 100",
          "legendFormat": "Cache Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 60 },
              { "color": "green", "value": 80 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Monthly Budget Burn",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(claude_session_cost_usd_total)",
          "legendFormat": "MTD Spend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 250 },
              { "color": "red", "value": 400 }
            ]
          },
          "min": 0,
          "max": 500
        }
      }
    },
    {
      "title": "Cost by Model",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (model) (claude_session_cost_usd_total)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "title": "Cost by Project",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum by (project) (claude_session_cost_usd_total)",
          "legendFormat": "{{project}}"
        }
      ]
    },
    {
      "title": "Sessions by Hour of Day",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (hour) (claude_session_count_total)",
          "legendFormat": "{{hour}}:00"
        }
      ]
    },
    {
      "title": "Token Breakdown (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(claude_session_input_tokens_total)",
          "legendFormat": "Input"
        },
        {
          "expr": "sum(claude_session_output_tokens_total)",
          "legendFormat": "Output"
        },
        {
          "expr": "sum(claude_session_cache_read_tokens_total)",
          "legendFormat": "Cache Read"
        },
        {
          "expr": "sum(claude_session_cache_write_tokens_total)",
          "legendFormat": "Cache Write"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "stacking": { "mode": "normal" }, "fillOpacity": 30 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["claude", "usage", "cost"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "title": "Claude Code Usage",
  "uid": "claude-usage-main"
}
