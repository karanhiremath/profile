#!/bin/bash

set -euo pipefail

shopt -s failglob

# Set PROFILE_DIR and APP_BIN if not already set
if [ -z "${PROFILE_DIR:-}" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    export PROFILE_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

if [ -z "${APP_BIN:-}" ]; then
    export APP_BIN="${PROFILE_DIR}/bin"
fi

. "${APP_BIN}/sh/shell_fns" --source-only
. "${APP_BIN}/sh/brew_helper.sh"

app_name="kubectl"

MACHINE="$(uname -s)"
ARCH="$(uname -m)"

if command -v kubectl >/dev/null 2>&1; then
    echo "kubectl already installed!"
    kubectl version --client --short 2>/dev/null || kubectl version --client
else
    install_messages "start" "$app_name"

    case "${MACHINE}" in
        Darwin|Mac)
            echo "Installing kubectl on Mac..."
            ensure_brew_in_path || {
                echo "ERROR: Homebrew not found. Please install Homebrew first."
                exit 1
            }
            brew install kubectl
            ;;
        Linux)
            echo "Installing kubectl on Linux..."
            # Download the latest stable release
            KUBE_VERSION="$(curl -L -s https://dl.k8s.io/release/stable.txt)"
            case "${ARCH}" in
                x86_64|amd64) KUBE_ARCH="amd64" ;;
                aarch64|arm64) KUBE_ARCH="arm64" ;;
                *)
                    echo "Unsupported architecture: ${ARCH}"
                    exit 1
                    ;;
            esac
            curl -LO "https://dl.k8s.io/release/${KUBE_VERSION}/bin/linux/${KUBE_ARCH}/kubectl"
            chmod +x kubectl
            sudo mv kubectl /usr/local/bin/kubectl
            ;;
        *)
            echo "Unsupported platform: ${MACHINE}"
            exit 1
            ;;
    esac

    install_messages "end" "$app_name"
fi

echo ""
echo "kubectl installed successfully!"
kubectl version --client --short 2>/dev/null || kubectl version --client
